# ═══════════════════════════════════════════════════════════════════════════════
# OmniRoute Multi-User — Docker Deployment .env
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and edit the values below, then run:
#
#   docker build --target runner-base -t omniroute-multiuser .
#   docker run -d --name omniroute -p 20128:20128 -v omniroute-data:/app/data --env-file .env omniroute-multiuser
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── 1. REQUIRED SECRETS (change these!) ───────────────────────────────────────

# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# Generate with: openssl rand -hex 32
API_KEY_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_HEX

# Legacy admin password (fallback for single-user mode)
INITIAL_PASSWORD=CHANGE_ME

# ─── 2. MULTI-USER MODE (the important one!) ──────────────────────────────────

# Set to true to enable multi-user platform mode
OMNIROUTE_MULTI_USER=true

# Commission rate (0.10 = 10%)
OMNIROUTE_DEFAULT_COMMISSION_RATE=0.10

# Minimum wallet balance to serve a request ($0.01 = 1 cent floor)
# Set to 0 to disable pre-flight balance check
OMNIROUTE_MIN_REQUEST_FLOOR_USD=0.01

# ─── 3. STRIPE (optional — leave empty to disable payments) ───────────────────

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── 4. SERVER ────────────────────────────────────────────────────────────────

PORT=20128
HOSTNAME=0.0.0.0

# ─── 5. DATABASE ──────────────────────────────────────────────────────────────

# SQLite data directory (inside container — mount as volume)
DATA_DIR=/app/data

# Disable auto-backup in Docker (use volume snapshots instead)
DISABLE_SQLITE_AUTO_BACKUP=true
